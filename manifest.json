{
  "manifest_version": 3,
  "name": "Bookmarks Manager",
  "version": "1.0",
  "description": "一个简单的书签管理器，支持自动归类、全局搜索功能",
  "permissions": [
    "bookmarks"
  ],
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
} 