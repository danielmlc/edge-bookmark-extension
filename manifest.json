{
  "manifest_version": 3,
  "name": "书签管理器",
  "version": "2.0",
  "description": "把浏览器原生书签以美观的整页网格形式展示，支持搜索、整理与个性化背景。",
  "permissions": ["bookmarks", "tabs"],
"background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "书签管理器"
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/*.js", "lib/*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
